{
  "name": "@geminixiang/mama",
  "version": "0.1.2",
  "description": "Slack bot that delegates messages to the pi coding agent",
  "keywords": [
    "agent",
    "ai",
    "bot",
    "discord",
    "slack",
    "telegram"
  ],
  "license": "MIT",
  "author": "geminixiang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geminixiang/mama.git"
  },
  "bin": {
    "mama": "dist/main.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.40",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.48",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "chalk": "^5.6.2",
    "croner": "^10.0.1",
    "diff": "^8.0.3",
    "discord.js": "^14.25.1",
    "grammy": "^1.41.1"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.4.0",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
