{
  "name": "@geminixiang/mama",
  "version": "0.2.0-beta.1",
  "description": "Slack bot that delegates messages to the pi coding agent",
  "keywords": [
    "agent",
    "ai",
    "bot",
    "discord",
    "slack",
    "telegram"
  ],
  "license": "MIT",
  "author": "geminixiang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geminixiang/mama.git"
  },
  "bin": {
    "mama": "dist/main.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json && shx chmod +x dist/main.js",
    "dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest --run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "@google-cloud/logging": "^11.2.1",
    "@mariozechner/pi-agent-core": "^0.69.0",
    "@mariozechner/pi-ai": "^0.69.0",
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@sentry/node": "^10.47.0",
    "@sinclair/typebox": "^0.34.49",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.0",
    "chalk": "^5.6.2",
    "croner": "^10.0.1",
    "diff": "^8.0.4",
    "discord.js": "^14.26.2",
    "grammy": "^1.42.0",
    "pino": "^10.3.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "shx": "^0.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "lint-staged": {
    "*.ts": [
      "npm run lint",
      "npm run fmt"
    ],
    "*.test.ts": [
      "npm run test"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
